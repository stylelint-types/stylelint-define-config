{
  "name": "stylelint-define-config",
  "type": "module",
  "version": "17.9.0",
  "packageManager": "pnpm@10.33.2",
  "description": "Provide a defineConfig function for stylelint.config.js files",
  "author": "pengzhanbo <volodymyr@foxmail.com> (https://github.com/pengzhanbo)",
  "license": "MIT",
  "homepage": "https://github.com/stylelint-types/stylelint-define-config#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/stylelint-types/stylelint-define-config.git"
  },
  "bugs": "https://github.com/stylelint-types/stylelint-define-config/issues",
  "keywords": [
    "config",
    "configuration",
    "define-config",
    "stylelint-config",
    "stylelint",
    "stylelintconfig",
    "typed",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "release:publish": "pnpm publish",
    "release:changelog": "conventional-changelog -p angular",
    "release": "bumpp package.json --execute=\"pnpm release:changelog\" --commit --all --push --tag"
  },
  "peerDependencies": {
    "stylelint": ">=17.0.0"
  },
  "dependencies": {
    "csstype": "^3.2.3"
  },
  "devDependencies": {
    "@pengzhanbo/eslint-config": "^2.4.0",
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-angular": "^8.3.1",
    "eslint": "^10.2.1",
    "stylelint": "^17.9.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "resolutions": {
    "baseline-browser-mapping": "^2.10.22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
